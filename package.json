{
  "name": "skill-manager-cli",
  "version": "0.3.0",
  "description": "CLI to discover and enable/disable skills across Claude Code, Cursor, and ~/.agents/skills",
  "type": "module",
  "bin": {
    "skills-manager": "./bin/skills-manager.mjs"
  },
  "files": [
    "dist",
    "bin",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/cli.ts",
    "skills-manager": "node ./bin/skills-manager.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "tsx scripts/release.ts"
  },
  "packageManager": "pnpm@9.15.9",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ylmz-smz/skill-manager.git"
  },
  "bugs": {
    "url": "https://github.com/ylmz-smz/skill-manager/issues"
  },
  "homepage": "https://github.com/ylmz-smz/skill-manager#readme",
  "keywords": [
    "cli",
    "skills",
    "claude",
    "cursor",
    "agents",
    "skill-manager"
  ],
  "engines": {
    "node": ">=20.12.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "commander": "^13.1.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5"
  },
  "license": "MIT"
}
